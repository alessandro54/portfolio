<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Alessandro Chumpitaz</title>
    <meta name="theme-color" content="#09080f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8f7fc" media="(prefers-color-scheme: light)" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/plus-jakarta-sans-var.woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @font-face {
        font-family: 'Plus Jakarta Sans';
        font-style: normal;
        font-weight: 300 800;
        font-display: swap;
        src: url('/fonts/plus-jakarta-sans-var.woff2') format('woff2');
      }
      * { margin: 0; box-sizing: border-box; }
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #09080f;
        color: #faf9ff;
        text-align: center;
        padding: 2rem;
      }
      @media (prefers-color-scheme: light) {
        body { background: #ffffff; color: #09090b; }
        .code { color: #8b5cf6; }
        .back { color: #8b5cf6; border-color: rgba(139,92,246,0.22); }
        .back:hover { border-color: #8b5cf6; }
        .dim { color: rgba(9,9,11,0.50); }
      }
      .code {
        font-size: clamp(4rem, 12vw, 7rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        color: #a78bfa;
      }
      .msg {
        font-size: 1.05rem;
        font-weight: 400;
        margin-top: 0.8rem;
        opacity: 0.62;
      }
      .back {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 2.2rem;
        padding: 0.55rem 1.6rem;
        border-radius: 7px;
        border: 1px solid rgba(167,139,250,0.22);
        background: transparent;
        color: #a78bfa;
        font-size: 0.82rem;
        font-weight: 600;
        text-decoration: none;
        transition: border-color 0.2s;
      }
      .back:hover { border-color: #a78bfa; }
      .dim { font-size: 0.68rem; margin-top: 2.5rem; color: rgba(250,249,255,0.42); letter-spacing: 0.08em; text-transform: uppercase; }
    </style>
  </head>
  <body>
    <div class="code">404</div>
    <div class="msg">This page doesn't exist.</div>
    <a href="/en/" class="back">&larr; Back home</a>
    <div class="dim">Alessandro Chumpitaz</div>
  </body>
</html>
