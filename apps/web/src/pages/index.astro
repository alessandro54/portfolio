<script src="../scripts/scene.ts"></script>
<script>
  // Scroll reveals
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      e.target.classList.add('in');
      const kids = e.target.querySelectorAll('.svc, .wk, .exp-row, .why-card, .why-feature');
      kids.forEach((k: Element, i: number) => {
        const el = k as HTMLElement;
        el.style.opacity = '0';
        el.style.transform = 'translateY(14px)';
        el.style.transition = `opacity .65s ${i * 0.07}s ease, transform .65s ${i * 0.07}s ease`;
        setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'none'; }, 60 + i * 70);
      });
    });
  }, { threshold: 0.07 });
  document.querySelectorAll('.r').forEach(el => io.observe(el));

  // Hero entrance
  const heroKids = document.querySelectorAll('.hero-badge, #hero h1, .hero-sub, .hero-btns, .hero-stats');
  heroKids.forEach((k: Element, i: number) => {
    const el = k as HTMLElement;
    el.style.opacity = '0';
    el.style.transform = 'translateY(22px)';
    el.style.transition = `opacity .9s ${0.15 + i * 0.11}s ease, transform .9s ${0.15 + i * 0.11}s ease`;
    setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'none'; }, 200 + i * 110);
  });

  // Theme toggle
  const btn = document.getElementById('theme-toggle') as HTMLButtonElement;
  const html = document.documentElement;
  function syncBtn() {
    btn.textContent = html.dataset.theme === 'light' ? '☽' : '☀';
  }
  syncBtn();
  btn.addEventListener('click', () => {
    html.dataset.theme = html.dataset.theme === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', html.dataset.theme);
    syncBtn();
  });
</script>
