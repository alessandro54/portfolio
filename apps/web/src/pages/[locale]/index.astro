---
import Cursor from '@components/shared/Cursor.astro';
import Footer from '@components/shared/Footer.astro';
import Nav from '@components/shared/Nav.astro';
import Layout from '@layouts/Layout.astro';
import Hero from '@sections/Hero.astro';
import Ticker from '@sections/Ticker.astro';
import WhatIDo from '@sections/WhatIDo.astro';
import WhyMe from '@sections/WhyMe.astro';
import SelectedProjects from '@sections/SelectedProjects.astro';
import Career from '@sections/Career.astro';
import Contact from '@sections/Contact.astro';

export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'es' } },
  ];
}

const { locale } = Astro.params;
---

<Layout locale={locale}>
  <canvas id="gl" aria-hidden="true"></canvas>
  <div id="vignette" aria-hidden="true"></div>

  <div class="site">
    <Nav locale={locale} />
    <main>
      <Hero locale={locale} />
      <Ticker locale={locale} />
      <WhatIDo locale={locale} />
      <WhyMe locale={locale} />
      <SelectedProjects locale={locale} />
      <Career locale={locale} />
      <Contact locale={locale} />
    </main>
    <Footer locale={locale} />
  </div>
  <Cursor />
</Layout>

<script>
  const loadScene = () => import('../../scripts/scene.ts');
  const loadAnims = () => import('../../scripts/animations.ts');
  if ('requestIdleCallback' in window) {
    requestIdleCallback(loadScene, { timeout: 200 });
    requestIdleCallback(loadAnims, { timeout: 1500 });
  } else {
    setTimeout(loadScene, 0);
    setTimeout(loadAnims, 100);
  }
</script>
