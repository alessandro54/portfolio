---
import ExperienceRow from './ExperienceRow.astro';
import SectionHeader from './SectionHeader.astro';

interface Props {
  jobs?: { date: string; company: string; role: string; desc: string }[];
}

const {
  jobs = [
    {
      date: '2023 — Present',
      company: 'Acme Graphics Corp',
      role: 'Senior Software Engineer',
      desc: 'Technical lead for a real-time 3D visualisation product. Rebuilt the rendering pipeline, cut infrastructure costs by 35%, and scaled the team from 3 to 6 engineers.',
    },
    {
      date: '2021 — 2023',
      company: 'Distributed Systems Co.',
      role: 'Software Engineer',
      desc: 'Owned the data ingestion platform handling 2M+ events/day. Delivered the streaming migration that became the foundation for three new product lines.',
    },
    {
      date: '2019 — 2021',
      company: 'TechStart Labs',
      role: 'Software Developer',
      desc: 'Full-stack development for a SaaS analytics dashboard used by 10,000+ businesses across 30 countries.',
    },
  ],
} = Astro.props;
---

<section id="experience" class="flex flex-col gap-2 px-12 pb-24 max-[900px]:px-6 max-[900px]:pb-16">
  <SectionHeader label="Career" title="Experience" />
  <div class="flex flex-col">
    {jobs.map((job, i) => <ExperienceRow {...job} first={i === 0} />)}
  </div>
</section>
