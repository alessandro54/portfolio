---
import SectionHeader from './SectionHeader.astro';
import ServiceCard from './ServiceCard.astro';

interface Props {
  services?: { icon: string; title: string; text: string }[];
}

const {
  services = [
    {
      icon: '⬡',
      title: 'System Architecture',
      text: 'Designing scalable, maintainable backend systems from the ground up. Distributed architecture, event-driven design, and long-term technical roadmaps.',
    },
    {
      icon: '◈',
      title: 'Performance Engineering',
      text: 'Diagnosing and eliminating bottlenecks at every layer. From GPU pipelines to database queries — I make software measurably faster.',
    },
    {
      icon: '◎',
      title: 'Technical Leadership',
      text: 'Acting as principal engineer or tech lead — setting standards, unblocking teams, reviewing code, and owning delivery end-to-end.',
    },
  ],
} = Astro.props;
---

<section id="services" class="flex flex-col gap-2 px-12 pt-24 pb-24 max-[900px]:px-6 max-[900px]:pt-16 max-[900px]:pb-16">
  <SectionHeader label="What I do" title="Services" soft="& Expertise" />
  <div class="grid grid-cols-3 gap-px border border-[var(--rule)] rounded-xl overflow-hidden max-[900px]:grid-cols-1">
    {services.map(svc => <ServiceCard {...svc} />)}
  </div>
</section>
