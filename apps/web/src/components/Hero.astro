---
import StatCard from './StatCard.astro';

interface Props {
  stats?: { value: number; suffix?: string; label: string }[];
}

const {
  stats = [
    { value: 7, label: 'Years in industry' },
    { value: 40, label: 'Projects delivered' },
    { value: 50, suffix: 'k', label: 'Daily active users' },
    { value: 3, label: 'Open-source libs' },
  ],
} = Astro.props;
---

<section id="hero" class="h-svh flex flex-col items-center justify-center text-center gap-6 px-8 pt-24 pb-12 relative max-[900px]:px-6 max-[900px]:pt-20">
  <div class="hero-badge inline-flex items-center gap-[0.55rem] text-[0.7rem] font-medium text-[var(--accent)] bg-[var(--accent-lo)] border border-[var(--accent-bd)] px-[0.9rem] py-[0.3rem] rounded-full mb-12 animate-[badge-pulse_2.5s_ease-in-out_infinite]">
    <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] animate-[blink_2.4s_infinite] shrink-0"></span>
    Available for new engagements
  </div>

  <h1 class="text-[clamp(2.4rem,5.2vw,4.8rem)] font-extrabold leading-[1.07] tracking-[-0.035em] mb-10 max-w-[800px] max-[900px]:text-[2.4rem]">
    <span class="bg-[linear-gradient(100deg,var(--fg)_0%,var(--accent)_50%,var(--h1-end)_100%)] bg-clip-text [-webkit-text-fill-color:transparent]">Senior Software Engineer</span><br>
    <span class="text-[var(--mid)] font-light">for teams that ship.</span>
  </h1>

  <p class="hero-sub text-[clamp(0.88rem,1.35vw,1.02rem)] font-normal leading-[1.8] text-[var(--mid)] max-w-[460px] mx-auto mb-14">
    I partner with startups and enterprises to architect and build
    high-performance systems — from concept to production.
    Fast, reliable, and built to last.
  </p>

  <div class="hero-btns flex gap-[0.8rem] justify-center mb-20">
    <a href="#contact" class="inline-flex items-center gap-[0.45rem] px-8 py-3.5 rounded-lg text-[0.82rem] font-medium no-underline bg-[var(--fg)] text-[var(--bg)] transition-all duration-[220ms] hover:opacity-88 hover:translate-y-[-1px]">Get in touch →</a>
    <a href="#work" class="inline-flex items-center gap-[0.45rem] px-8 py-3.5 rounded-lg text-[0.82rem] font-medium no-underline bg-transparent border border-[var(--rule)] text-[var(--mid)] transition-all duration-[220ms] hover:border-[var(--accent-bd)] hover:text-[var(--fg)]">See my work</a>
  </div>

  <div class="hero-stats flex items-center border border-[var(--rule)] rounded-xl overflow-hidden bg-[rgba(var(--vig-rgb),0.55)] backdrop-blur-[16px] max-[900px]:flex-wrap max-[900px]:rounded-[10px]">
    {stats.map((stat, i) => <StatCard {...stat} border={i < stats.length - 1} />)}
  </div>

  <div class="scroll-cue absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <span class="text-[0.56rem] tracking-[0.22em] uppercase text-[var(--dim)]">Scroll</span>
    <div class="w-px h-9 bg-[linear-gradient(to_bottom,var(--dim),transparent)] animate-[scrl_2s_infinite]"></div>
  </div>
</section>
