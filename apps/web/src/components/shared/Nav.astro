---
import ThemeDropdown from './ThemeDropdown.astro';
import LangDropdown from './LangDropdown.astro';
import { useTranslations } from '@i18n/translations';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const ui = useTranslations(locale);
---

<nav class="fixed inset-x-0 top-0 z-100 flex items-center justify-between px-12 py-[1.3rem] bg-[var(--nav-bg)] backdrop-blur-[20px] border-b border-[var(--rule)] transition-[background,border-color] duration-400 max-[900px]:px-6 max-[900px]:py-4">
  <div class="flex items-center gap-2.5 font-bold text-[0.9rem] tracking-[-0.01em] text-[var(--fg)]">
    <svg viewBox="0 0 100 100" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" class="w-5 h-5">
      <line x1="68" y1="40" x2="68" y2="81" /><line x1="68" y1="40" x2="69" y2="13" />
      <line x1="68" y1="40" x2="31" y2="20" /><line x1="68" y1="40" x2="92" y2="50" />
      <line x1="68" y1="40" x2="30" y2="63" /><line x1="68" y1="81" x2="69" y2="80" />
      <line x1="68" y1="81" x2="31" y2="87" /><line x1="68" y1="81" x2="92" y2="50" />
      <line x1="68" y1="81" x2="30" y2="63" /><line x1="32" y1="19" x2="32" y2="60" />
      <line x1="32" y1="19" x2="69" y2="13" /><line x1="32" y1="19" x2="31" y2="20" />
      <line x1="32" y1="19" x2="70" y2="37" /><line x1="32" y1="19" x2="8" y2="50" />
      <line x1="32" y1="60" x2="69" y2="80" /><line x1="32" y1="60" x2="31" y2="87" />
      <line x1="32" y1="60" x2="70" y2="37" /><line x1="32" y1="60" x2="8" y2="50" />
      <line x1="69" y1="13" x2="31" y2="20" /><line x1="69" y1="13" x2="92" y2="50" />
      <line x1="69" y1="13" x2="70" y2="37" /><line x1="31" y1="20" x2="30" y2="63" />
      <line x1="31" y1="20" x2="8" y2="50" /><line x1="69" y1="80" x2="31" y2="87" />
      <line x1="69" y1="80" x2="92" y2="50" /><line x1="69" y1="80" x2="70" y2="37" />
      <line x1="31" y1="87" x2="30" y2="63" /><line x1="31" y1="87" x2="8" y2="50" />
      <line x1="92" y1="50" x2="70" y2="37" /><line x1="30" y1="63" x2="8" y2="50" />
    </svg>
    Alessandro C.
  </div>
  <div class="flex gap-[2.6rem] max-[900px]:hidden">
    <a href="#services" class="text-[0.78rem] font-normal text-[var(--mid)] no-underline transition-colors duration-200 hover:text-[var(--fg)]">{ui('nav_services')}</a>
    <a href="#work" class="text-[0.78rem] font-normal text-[var(--mid)] no-underline transition-colors duration-200 hover:text-[var(--fg)]">{ui('nav_work')}</a>
    <a href="#experience" class="text-[0.78rem] font-normal text-[var(--mid)] no-underline transition-colors duration-200 hover:text-[var(--fg)]">{ui('nav_experience')}</a>
    <a href="#contact" class="text-[0.78rem] font-normal text-[var(--mid)] no-underline transition-colors duration-200 hover:text-[var(--fg)]">{ui('nav_contact')}</a>
  </div>
  <div class="flex items-center gap-3">
    <ThemeDropdown />
    <LangDropdown locale={locale} />
    <a href="#contact" class="nav-cta inline-flex items-center gap-[0.4rem] px-5 py-[0.52rem] rounded-[7px] bg-[var(--accent)] text-[#09080f] text-[0.76rem] font-semibold no-underline transition-[opacity,transform] duration-200 hover:opacity-88 hover:translate-y-[-1px]">{ui('nav_hire')}</a>
  </div>
</nav>
