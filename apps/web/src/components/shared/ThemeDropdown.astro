---
---
<div class="theme-dropdown relative" data-dropdown>
  <button
    id="theme-trigger"
    class="flex items-center justify-center w-8 h-8 rounded-lg border border-[var(--rule)] text-[var(--mid)] text-[0.82rem] transition-[border-color,color] duration-200 hover:border-[var(--accent)] hover:text-[var(--accent)]"
    aria-label="Theme"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <svg class="theme-icon theme-icon--system w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" /></svg>
    <svg class="theme-icon theme-icon--dark w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
    <svg class="theme-icon theme-icon--light w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" /></svg>
  </button>
  <div class="dropdown-panel absolute right-0 top-full mt-2 min-w-[130px] rounded-lg border border-[var(--rule)] bg-[var(--surface)] backdrop-blur-[16px] py-1 shadow-lg opacity-0 invisible transition-[opacity,visibility] duration-150 z-50">
    <button data-theme-value="system" class="dropdown-item flex items-center gap-2 w-full px-3 py-1.5 text-[0.75rem] text-[var(--mid)] hover:text-[var(--fg)] hover:bg-[var(--rule)] transition-colors duration-150 text-left">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" /></svg>
      System
    </button>
    <button data-theme-value="dark" class="dropdown-item flex items-center gap-2 w-full px-3 py-1.5 text-[0.75rem] text-[var(--mid)] hover:text-[var(--fg)] hover:bg-[var(--rule)] transition-colors duration-150 text-left">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
      Dark
    </button>
    <button data-theme-value="light" class="dropdown-item flex items-center gap-2 w-full px-3 py-1.5 text-[0.75rem] text-[var(--mid)] hover:text-[var(--fg)] hover:bg-[var(--rule)] transition-colors duration-150 text-left">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" /></svg>
      Light
    </button>
  </div>
</div>

<style is:global>
  .theme-icon { display: none; }
  [data-theme-pref="system"] .theme-icon--system { display: block; }
  [data-theme-pref="dark"] .theme-icon--dark { display: block; }
  [data-theme-pref="light"] .theme-icon--light { display: block; }
  .theme-dropdown .dropdown-panel.open { opacity: 1; visibility: visible; }
  .theme-dropdown .dropdown-item.active { color: var(--accent); }
</style>

<script>
  const root = document.documentElement;
  const trigger = document.getElementById('theme-trigger')!;
  const panel = trigger.nextElementSibling as HTMLElement;
  const items = panel.querySelectorAll<HTMLButtonElement>('[data-theme-value]');
  const mq = window.matchMedia('(prefers-color-scheme: light)');

  function applyTheme(pref: string) {
    const theme = pref === 'system'
      ? (mq.matches ? 'light' : 'dark')
      : pref;
    root.dataset.theme = theme;
    root.dataset.themePref = pref;
    localStorage.setItem('theme', pref);
    items.forEach(b => b.classList.toggle('active', b.dataset.themeValue === pref));
  }

  applyTheme(localStorage.getItem('theme') || 'system');

  mq.addEventListener('change', () => {
    if (root.dataset.themePref === 'system') applyTheme('system');
  });

  trigger.addEventListener('click', () => {
    const open = panel.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(open));
  });

  items.forEach(btn => {
    btn.addEventListener('click', () => {
      applyTheme(btn.dataset.themeValue!);
      panel.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.theme-dropdown')) {
      panel.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    }
  });
</script>
