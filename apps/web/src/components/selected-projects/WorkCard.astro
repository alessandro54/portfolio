---
interface Props {
  num: string;
  title: string;
  outcome: string;
  tags: string[];
  liveUrl?: string;
  repos?: { label: string; url: string }[];
}

const { num, title, outcome, tags, liveUrl, repos = [] } = Astro.props;
const href = liveUrl || repos[0]?.url;
---

<div class:list={['wk bg-[var(--bg)] p-8 flex flex-col gap-2 transition-colors duration-250 hover:bg-[var(--surface)] group', href ? 'cursor-pointer' : 'cursor-default']}>
  {href ? (
    <a href={href} target="_blank" class="contents no-underline text-inherit">
      <div class="flex justify-between">
        <span class="text-[0.58rem] tracking-[0.1em] text-[var(--dim)]">{num}</span>
        <span class="text-[0.75rem] text-[var(--dim)] transition-[transform,color] duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-[var(--accent)]">↗</span>
      </div>
      <div class="text-[clamp(1rem,1.4vw,0.93rem)] font-semibold tracking-[-0.01em] text-[var(--fg)]">{title}</div>
      <p class="text-[clamp(0.88rem,1.2vw,0.78rem)] leading-[1.78] text-[var(--mid)] flex-1 text-justify">{outcome}</p>
      <div class="wk-tags flex flex-wrap gap-[0.3rem] pt-[0.7rem] border-t border-[var(--rule)]">
        {tags.map(tag => <span class="text-[0.6rem] px-[0.52rem] py-[0.18rem] rounded bg-[var(--accent-lo)] text-[var(--dim)]">{tag}</span>)}
      </div>
    </a>
  ) : (
    <>
      <div class="flex justify-between">
        <span class="text-[0.58rem] tracking-[0.1em] text-[var(--dim)]">{num}</span>
      </div>
      <div class="text-[clamp(1rem,1.4vw,0.93rem)] font-semibold tracking-[-0.01em] text-[var(--fg)]">{title}</div>
      <p class="text-[clamp(0.88rem,1.2vw,0.78rem)] leading-[1.78] text-[var(--mid)] flex-1 text-justify">{outcome}</p>
      <div class="wk-tags flex flex-wrap gap-[0.3rem] pt-[0.7rem] border-t border-[var(--rule)]">
        {tags.map(tag => <span class="text-[0.6rem] px-[0.52rem] py-[0.18rem] rounded bg-[var(--accent-lo)] text-[var(--dim)]">{tag}</span>)}
      </div>
    </>
  )}
</div>
