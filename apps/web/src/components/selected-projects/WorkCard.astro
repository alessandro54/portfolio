---
interface Props {
  num: string;
  kind?: string;
  title: string;
  outcome: string;
  tags: string[];
  liveUrl?: string;
  repos?: { label: string; url: string }[];
}

const { num, kind = 'project', title, outcome, tags, liveUrl, repos = [] } = Astro.props;
const isOss = kind === 'oss';
const href = isOss ? repos[0]?.url : liveUrl || repos[0]?.url;

function prLabel(url: string): string {
  const match = url.match(/\/pull\/(\d+)/);
  return match ? `PR #${match[1]}` : 'View PR';
}
---

<div class="wk bg-[var(--bg)] p-8 flex flex-col gap-2 transition-colors duration-250 hover:bg-[var(--surface)] group cursor-default">
  <div class="flex justify-between items-center">
    <div class="flex items-center gap-2">
      <span class="text-[0.58rem] tracking-[0.1em] text-[var(--dim)]">{num}</span>
      {isOss && <span class="text-[0.55rem] font-bold tracking-[0.1em] uppercase px-[0.5rem] py-[0.15rem] rounded-[5px] text-white bg-[var(--accent)]">OSS Contrib</span>}
    </div>
    {!isOss && href && (
      <a href={href} target="_blank" class="text-[0.75rem] text-[var(--dim)] transition-[transform,color] duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-[var(--accent)] no-underline">↗</a>
    )}
  </div>

  <div class="text-[clamp(1rem,1.4vw,0.93rem)] font-semibold tracking-[-0.01em] text-[var(--fg)]">{title}</div>

  {isOss && href && (
    <a href={href} target="_blank" class="inline-flex items-center gap-[0.4rem] text-[0.72rem] font-medium text-[var(--accent)] no-underline hover:text-[var(--fg)] transition-colors duration-200 w-fit">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
      {prLabel(href)} ↗
    </a>
  )}

  <p class="text-[clamp(0.88rem,1.2vw,0.78rem)] leading-[1.78] text-[var(--mid)] flex-1 text-justify">{outcome}</p>

  {repos.length > 0 && !isOss && (
    <div class="flex flex-wrap gap-[0.5rem]">
      {repos.map(r => (
        <a href={r.url} target="_blank" class="text-[0.6rem] font-medium text-[var(--accent)] no-underline hover:text-[var(--fg)] transition-colors duration-200">{r.label} ↗</a>
      ))}
    </div>
  )}

  <div class="wk-tags flex flex-wrap gap-[0.3rem] pt-[0.7rem] border-t border-[var(--rule)]">
    {tags.map(tag => <span class="text-[0.6rem] px-[0.52rem] py-[0.18rem] rounded bg-[var(--accent-lo)] text-[var(--dim)]">{tag}</span>)}
  </div>
</div>
