---
interface Props {
  value: number;
  suffix?: string;
  label: string;
  border?: boolean;
}

const { value, suffix, label, border = true } = Astro.props;
---

<div class={`flex flex-col gap-2 px-10 py-5 text-center ${border ? 'border-r border-[var(--accent-bd)]' : ''} max-[900px]:border-b max-[900px]:border-[var(--rule)] max-[900px]:w-1/2 max-[900px]:px-4 max-[900px]:box-border`}>
  <div class="text-2xl font-extrabold tracking-[-0.04em] text-[var(--fg)] leading-none mb-2.5">
    <span class="stat-num" data-target={String(value)} data-suffix={suffix || undefined}>0</span>
    {!suffix && <Fragment />}
  </div>
  <div class="text-[0.6rem] font-normal tracking-[0.08em] text-[var(--dim)] uppercase">{label}</div>
</div>
