---
import '../styles/global.css';
import { useTranslations } from '@i18n/translations';
import { sanityClient } from '@lib/sanity';
import { createImageUrlBuilder } from '@sanity/image-url';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const ui = useTranslations(locale);
const otherLocale = locale === 'en' ? 'es' : 'en';

const seo = await sanityClient.fetch(
  `*[_id == "singleton-seo"][0]{
    metaTitle, metaDescription, siteName, siteUrl,
    ogImage, twitterHandle, twitterCardType,
    themeColorDark, themeColorLight,
    appleTouchIcon, appleStatusBarStyle, appleMobileWebAppTitle,
    robotsDirective, author, keywords
  }`
);

const t = (field: Record<string, string> | null) => field?.[locale] || field?.en || '';

const builder = createImageUrlBuilder({ projectId: 'sczvled1', dataset: 'production' });
const ogImageUrl = seo?.ogImage ? builder.image(seo.ogImage).width(1200).height(630).url() : null;
const appleTouchIconUrl = seo?.appleTouchIcon ? builder.image(seo.appleTouchIcon).width(180).height(180).format('png').url() : null;

const title = t(seo?.metaTitle) || ui('meta_title');
const description = t(seo?.metaDescription) || ui('meta_description');
const siteName = seo?.siteName || 'Alessandro Chumpitaz';
const siteUrl = seo?.siteUrl || 'https://alessandro.chumpitaz.dev';
const canonical = `${siteUrl}/${locale}/`;
const alternate = `${siteUrl}/${otherLocale}/`;
const keywords = t(seo?.keywords) || '';
const author = seo?.author || '';
const robots = seo?.robotsDirective || 'index, follow';
const twitterCard = seo?.twitterCardType || 'summary_large_image';
const twitterHandle = seo?.twitterHandle || '';
const themeColorDark = seo?.themeColorDark || '#09080f';
const themeColorLight = seo?.themeColorLight || '#f8f7fc';
const statusBarStyle = seo?.appleStatusBarStyle || 'black-translucent';
const appTitle = seo?.appleMobileWebAppTitle || siteName;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {author && <meta name="author" content={author} />}
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={locale === 'es' ? 'en_US' : 'es_ES'} />
    <meta property="og:site_name" content={siteName} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link rel="alternate" hreflang={otherLocale} href={alternate} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Apple -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content={statusBarStyle} />
    <meta name="apple-mobile-web-app-title" content={appTitle} />
    {appleTouchIconUrl && <link rel="apple-touch-icon" href={appleTouchIconUrl} />}

    <!-- Theme -->
    <meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Critical CSS — paint without waiting for external stylesheet -->
    <style is:inline>
      :root{--bg:#09080f;--surface:#130f24;--fg:#faf9ff;--mid:rgba(250,249,255,0.62);--dim:rgba(250,249,255,0.42);--rule:rgba(250,249,255,0.07);--accent:#a78bfa;--accent-lo:rgba(167,139,250,0.10);--accent-bd:rgba(167,139,250,0.22);--nav-bg:rgba(9,8,15,0.70);--vig-rgb:9,8,15;--gradient-end:#e879f9;--h1-end:#fff}
      html[data-theme="light"]{--bg:#fff;--surface:#f5f3ff;--fg:#09090b;--mid:rgba(9,9,11,0.68);--dim:rgba(9,9,11,0.62);--rule:rgba(9,9,11,0.08);--accent:#7c3aed;--accent-lo:rgba(124,58,237,0.08);--accent-bd:rgba(124,58,237,0.20);--nav-bg:rgba(255,255,255,0.85);--vig-rgb:255,255,255;--gradient-end:#a855f7;--h1-end:#a855f7}
      *,*::before,*::after{margin:0;box-sizing:border-box}
      body{background:var(--bg);color:var(--fg);font-family:'Jakarta Heading',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;overflow-x:hidden;-webkit-font-smoothing:antialiased}
      #gl{position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;display:block}
      #vignette{position:fixed;inset:0;z-index:1;pointer-events:none;background:radial-gradient(ellipse 65% 65% at 50% 50%,rgba(var(--vig-rgb),0.55) 0%,rgba(var(--vig-rgb),0.30) 40%,transparent 70%)}
      nav,.hero-badge,#hero h1 span,.hero-sub,.hero-btns a,.hero-stats,.scroll-cue,.ticker-wrap,.s-label,section:not(#contact) h2,#services .grid,.why-grid,#work .grid,.exp-row,#contact .flex.flex-col>a{visibility:hidden}
    </style>
    <script is:inline>
      (function(){
        var pref = localStorage.getItem('theme') || 'system';
        var theme;
        if (pref === 'system') {
          theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        } else {
          theme = pref;
        }
        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.themePref = pref;
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
