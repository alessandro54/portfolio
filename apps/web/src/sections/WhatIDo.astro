---
import SectionHeader from '@components/shared/SectionHeader.astro';
import ServiceCard from '@components/what-i-do/ServiceCard.astro';
import { sanityClient } from '@lib/sanity';
import { useTranslations } from '@i18n/translations';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const ui = useTranslations(locale);

const data = await sanityClient.fetch(
  `*[_id == "singleton-whatIDo"][0]{ "services": services[0...3]{ _key, icon, title, text } }`
);

const t = (field: Record<string, string> | null) =>
  field?.[locale] || field?.en || '';

const services: { icon: string; title: string; text: string }[] =
  (data?.services ?? []).map(
    (s: { icon: string; title: Record<string, string>; text: Record<string, string> }) => ({
      icon: s.icon,
      title: t(s.title),
      text: t(s.text),
    })
  );
---

<section id="services" class="flex flex-col gap-2 px-12 pt-24 pb-24 max-[900px]:px-8 max-[900px]:pt-16 max-[900px]:pb-16">
  <SectionHeader label={ui('what_i_do_label')} title={ui('what_i_do_title')} soft={ui('what_i_do_soft')} />
  <div class="grid grid-cols-3 gap-px border border-[var(--rule)] rounded-xl overflow-hidden max-[900px]:grid-cols-1">
    {services.map(svc => <ServiceCard {...svc} />)}
  </div>
</section>
