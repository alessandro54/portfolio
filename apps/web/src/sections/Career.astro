---
import ExperienceRow from '@components/career/ExperienceRow.astro';
import SectionHeader from '@components/shared/SectionHeader.astro';
import { sanityClient } from '@lib/sanity';
import { useTranslations } from '@i18n/translations';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const ui = useTranslations(locale);

const raw = await sanityClient.fetch(
  `*[_type == "experience"] | order(order asc) { company, role, startDate, endDate, description, techStack }`
);

type Block = { children?: { text?: string }[] };

const jobs = raw.map((e: { company: string; role: string; startDate: string; endDate?: string; description?: Block[]; techStack?: string[] }) => {
  const start = e.startDate?.slice(0, 4) ?? '';
  const end = e.endDate ? e.endDate.slice(0, 4) : ui('career_present');
  const date = `${start} — ${end}`;
  const desc = (e.description ?? [])
    .flatMap((b: Block) => b.children ?? [])
    .map((s) => s.text ?? '')
    .join('');
  return { date, company: e.company, role: e.role, desc, techStack: e.techStack ?? [] };
});
---

<section id="experience" class="flex flex-col gap-2 px-12 pb-24 max-[900px]:px-6 max-[900px]:pb-16">
  <SectionHeader label={ui('career_label')} title={ui('career_title')} />
  <div class="flex flex-col">
    {jobs.map((job, i) => <ExperienceRow {...job} first={i === 0} />)}
  </div>
</section>
