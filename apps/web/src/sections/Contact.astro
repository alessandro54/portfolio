---
import { useTranslations } from '@i18n/translations';
import { sanityClient } from '@lib/sanity';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const ui = useTranslations(locale);

const data = await sanityClient.fetch(
  `*[_id == "singleton-contact"][0]{
    email,
    github,
    linkedin,
    "resume": resumes[locale == $locale] | order(date desc)[0]{ "url": file.asset->url, label, date }
  }`,
  { locale },
);

const resumeFallback = !data?.resume
  ? await sanityClient.fetch(
      `*[_id == "singleton-contact"][0]{
        "resume": resumes[locale == "en"] | order(date desc)[0]{ "url": file.asset->url, label, date }
      }`,
    )
  : null;

const email = data?.email || 'alessandro@chumpitaz.dev';
const github = data?.github || 'https://github.com/alessandro54';
const linkedin = data?.linkedin || 'https://www.linkedin.com/in/alessandrochumpitaz/';
const resumeUrl = data?.resume?.url || resumeFallback?.resume?.url;
---

<section id="contact" class="border-t border-[var(--rule)] px-12 py-[5.5rem] max-[900px]:px-6 relative z-10 bg-[color-mix(in_srgb,var(--bg)_70%,transparent)] backdrop-blur-xl transition-colors duration-250 hover:bg-[color-mix(in_srgb,var(--bg)_90%,transparent)]">
  <div class="grid grid-cols-2 gap-16 items-center max-[900px]:grid-cols-1 max-[900px]:gap-12" style="max-width:900px;margin-inline:auto">
    <div>
      <h2 class="text-[clamp(1.8rem,3vw,2.8rem)] font-bold tracking-[-0.03em] text-[var(--fg)] leading-[1.1] mb-4">{ui('contact_heading_pre')}<br>something <em class="not-italic bg-[linear-gradient(100deg,var(--accent)_10%,var(--gradient-end)_80%)] bg-clip-text [-webkit-text-fill-color:transparent]">{ui('contact_heading_em')}</em></h2>
      <p class="text-[0.82rem] leading-[1.82] text-[var(--mid)]">{ui('contact_body')}</p>
    </div>
    <div class="flex flex-col gap-[1.2rem]">
      <a href={`mailto:${email}`} class="flex items-center justify-between px-[1.3rem] py-[1.1rem] rounded-[10px] bg-[var(--surface)] border border-[var(--rule)] no-underline transition-[border-color] duration-200 hover:border-[var(--accent)]">
        <div>
          <div class="text-[0.6rem] font-medium tracking-[0.1em] uppercase text-[var(--dim)] mb-[0.2rem]">{ui('contact_email_label')}</div>
          <div class="text-[0.86rem] font-medium text-[var(--fg)]">{email}</div>
        </div>
        <span class="text-[0.78rem] text-[var(--dim)]">→</span>
      </a>
      <div class="flex gap-[0.6rem]">
        <a href={github} target="_blank" class="flex-1 py-[0.7rem] rounded-lg flex items-center justify-center gap-[0.4rem] bg-[var(--surface)] border border-[var(--rule)] text-[0.72rem] font-medium text-[var(--mid)] no-underline transition-[border-color,color] duration-200 hover:border-[var(--accent)] hover:text-[var(--fg)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          {ui('contact_github')}
        </a>
        <a href={linkedin} target="_blank" class="flex-1 py-[0.7rem] rounded-lg flex items-center justify-center gap-[0.4rem] bg-[var(--surface)] border border-[var(--rule)] text-[0.72rem] font-medium text-[var(--mid)] no-underline transition-[border-color,color] duration-200 hover:border-[var(--accent)] hover:text-[var(--fg)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          {ui('contact_linkedin')}
        </a>
        {resumeUrl && (
          <a href={resumeUrl} target="_blank" class="flex-1 py-[0.7rem] rounded-lg flex items-center justify-center gap-[0.4rem] bg-[var(--surface)] border border-[var(--rule)] text-[0.72rem] font-medium text-[var(--mid)] no-underline transition-[border-color,color] duration-200 hover:border-[var(--accent)] hover:text-[var(--fg)]">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {ui('contact_resume')}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
