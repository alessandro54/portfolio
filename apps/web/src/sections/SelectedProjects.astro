---
import SectionHeader from '@components/shared/SectionHeader.astro';
import WorkCard from '@components/selected-projects/WorkCard.astro';
import { sanityClient } from '@lib/sanity';
import { useTranslations } from '@i18n/translations';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const ui = useTranslations(locale);

const data = await sanityClient.fetch(
  `*[_id == "singleton-selectedProjects"][0]{ items[]{ _key, num, title, outcome, tags } }`
);

const t = (field: Record<string, string> | null) =>
  field?.[locale] || field?.en || '';

const projects: { num: string; title: string; outcome: string; tags: string[] }[] =
  (data?.items ?? []).map((p: { num: string; title: Record<string, string>; outcome: Record<string, string>; tags: string[] }) => ({
    num: p.num,
    title: t(p.title),
    outcome: t(p.outcome),
    tags: p.tags ?? [],
  }));
---

<section id="work" class="flex flex-col gap-2 px-12 pb-24 max-[900px]:px-6 max-[900px]:pb-16">
  <SectionHeader label={ui('projects_label')} title={ui('projects_title')} soft={ui('projects_soft')} />
  <div class="grid grid-cols-2 gap-px bg-[var(--rule)] border border-[var(--rule)] rounded-xl overflow-hidden max-[900px]:grid-cols-1">
    {projects.map(p => <WorkCard {...p} />)}
  </div>
</section>
