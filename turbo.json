{
  "$schema": "https://v2-9-5.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "dependsOn": ["build"]
    },
    "deploy": {
      "cache": false
    },
    "schema:deploy": {
      "cache": false
    }
  }
}
